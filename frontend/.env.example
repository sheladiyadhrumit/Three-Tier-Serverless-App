# ─── API URL ─────────────────────────────────────────────────────────────────
# Get this AFTER deploying backend with: npx serverless deploy
# It will output your API Gateway URL like:
# endpoints: ANY - https://abc123.execute-api.ap-south-1.amazonaws.com/prod/{proxy+}
# Copy the base URL (without /{proxy+}):
REACT_APP_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# ─── INSTRUCTIONS ─────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in REACT_APP_API_URL with your actual API Gateway URL
# 3. Run: npm start (for local dev)
# 4. For CI/CD: Add REACT_APP_API_URL as a GitHub Secret
