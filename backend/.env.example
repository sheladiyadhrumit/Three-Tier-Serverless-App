# ─── Database (Amazon RDS MySQL) ─────────────────────────────────────────────
# Get DB_HOST from: AWS Console > RDS > your-database > Endpoint
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_USER=admin
DB_PASS=your-strong-password-here
DB_NAME=myapp

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
# Get from: AWS Console > CloudFront > your-distribution > Domain Name
FRONTEND_URL=https://your-distribution-id.cloudfront.net

# ─── VPC Configuration ────────────────────────────────────────────────────────
# Get from: AWS Console > VPC > Security Groups
LAMBDA_SECURITY_GROUP=sg-xxxxxxxxxxxxxxxxx

# Get from: AWS Console > VPC > Subnets (choose private subnets)
PRIVATE_SUBNET_1=subnet-xxxxxxxxxxxxxxxxx
PRIVATE_SUBNET_2=subnet-yyyyyyyyyyyyyyyyy

# ─── INSTRUCTIONS ─────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values above
# 3. NEVER commit .env to git (it's in .gitignore)
# 4. For CI/CD: Add all these as GitHub Secrets
